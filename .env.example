# Option 1: Single connection string (recommended for Coolify / production)
# DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5432/yaft

# Option 2: Individual vars (used for local dev with docker-compose)
DB_HOST=localhost
DB_PORT=5050
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=yaft

# better-auth (required)
BETTER_AUTH_SECRET=at-least-32-characters-long-secret-key-change-me
BETTER_AUTH_URL=http://localhost:3000

# OAuth — OPTIONAL (omit to run with email/password only)
# Social login buttons only appear if these are set.

# GitHub: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
#GITHUB_CLIENT_ID=
#GITHUB_CLIENT_SECRET=

# Google: https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3000/api/auth/callback/google
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=

# Optional: seed script admin user
ADMIN_EMAIL=admin@yaft.local
ADMIN_PASSWORD=changeme
